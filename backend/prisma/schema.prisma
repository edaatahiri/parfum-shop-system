// Konfigurimi i Gjeneratorit
generator client {
  provider = "prisma-client-js"
}

// Lidhja me Databazën (MySQL)
datasource db {
  provider = "mysql"
  url=env("DATABASE_URL")
}

// Tabelat
model Parfum {
  parfum_id     Int     @id @default(autoincrement())
  emri          String
  gjinia_target String
  volumi_ml     Int
  cmimi         Float
  sasia_stok    Int
  pershkrimi    String?
  notat_ere     String?

  kategoria_id Int
  marka_id     Int

  kategoria Kategoria @relation(fields: [kategoria_id], references: [kategori_id])
  marka     Markat    @relation(fields: [marka_id], references: [marka_id])

  mostrats        Mostrat[]
  detajetShitjes  Detajet_Shitjes[]
  detajetPorosise Detajet_Porosise_Furnitorit[]
  reviews Reviews[]
  wishlist Wishlist[]
}

model Kategoria {
  kategori_id Int     @id @default(autoincrement())
  emri        String  @unique
  pershkrimi  String?

  parfumet Parfum[]
}

model Klientet {
  id                Int      @id @default(autoincrement())
  emri              String
  mbiemri           String
  telefoni          String?
  email             String   @unique
  data_lindjes      DateTime
  gjinia            String
  adresa            String
  data_regjistrimit DateTime @default(now())
  piket_besnikerise Int      @default(0)

  shitjet Shitjet[]
  reviews Reviews[]
  wishlist Wishlist[]
}

model Markat {
  marka_id         Int     @id @default(autoincrement())
  emri             String  @unique
  shteti_origjines String?
  website          String?
  pershkrimi       String?
  logoja           String?

  parfumet Parfum[]
}

model Ofertat {
  oferte_id          Int      @id @default(autoincrement())
  emri               String
  pershkrimi         String?
  perqindja_zbritjes Float
  data_fillimit      DateTime
  data_perfundimit   DateTime
  statusi            String
}

model Mostrat {
  mostre_id  Int    @id @default(autoincrement())
  sasia_stok Int
  volumi_ml  Int
  statusi    String

  parfum_id Int
  parfumi   Parfum @relation(fields: [parfum_id], references: [parfum_id])
}

model Users {
  id                  Int      @id @default(autoincrement())
  emri                String
  mbiemri             String
  email               String   @unique
  password_hash       String
  phone_number        String?
  email_confirmed     Boolean  @default(false)
  lockout_enabled     Boolean  @default(true)
  access_failed_count Int      @default(0)
  data_krijimit       DateTime @default(now())
  statusi             String   @default("Active")

  userRoles     UserRoles[]
  userClaims    UserClaims[]
  userTokens    UserTokens[]
  refreshTokens RefreshTokens[]
}

model Roles {
  id              Int     @id @default(autoincrement())
  emertimi        String  @unique
  pershkrimi      String?
  normalized_name String?

  userRoles UserRoles[]
}

model UserRoles {
  id Int @id @default(autoincrement())

  user_id Int
  role_id Int

  user Users @relation(fields: [user_id], references: [id])
  role Roles @relation(fields: [role_id], references: [id])
}

model Reviews{
  review_id Int @id @default(autoincrement())
  rating Int 
  komenti String? @db.Text
  data DateTime @default(now())

  klient_id Int
  parfum_id Int

  klient Klientet @relation(fields: [klient_id], references: [id])
  parfumi Parfum @relation(fields: [parfum_id], references: [parfum_id])
}

model Wishlist{
  wishlist_id Int @id @default(autoincrement())
  data_shtimit DateTime @default(now())

  klient_id Int
  parfum_id Int

  klient Klientet @relation(fields: [klient_id], references: [id])
  parfumi Parfum @relation(fields: [parfum_id], references: [parfum_id])

  @@unique([klient_id,parfum_id])
}

model UserClaims {
  id          Int    @id @default(autoincrement())
  user_id     Int
  claim_type  String
  claim_value String

  user Users @relation(fields: [user_id], references: [id])
}

model UserTokens {
  id             Int    @id @default(autoincrement())
  user_id        Int
  login_provider String
  token_name     String
  token_value    String

  user Users @relation(fields: [user_id], references: [id])
}

model RefreshTokens {
  id      Int      @id @default(autoincrement())
  user_id Int
  token   String
  expires DateTime
  created DateTime @default(now())
  revoked Boolean  @default(false)

  user Users @relation(fields: [user_id], references: [id])
}

model Punetoret {
  punetor_id     Int      @id @default(autoincrement())
  emri           String
  mbiemri        String
  pozita         String
  telefoni       String?
  email          String
  data_punesimit DateTime
  paga           Float

  shitjet Shitjet[]
}

model Furnitoret {
  furnitor_id       Int    @id @default(autoincrement())
  emri              String
  personi_kontaktit String
  telefoni          String
  email             String
  adresa            String
  shteti            String

  porosite Porosite_Furnitoreve[]
}

model Shitjet {
  shitje_id      Int      @id @default(autoincrement())
  klient_id      Int
  punetor_id     Int
  data_shitjes   DateTime
  shuma_totale   Float
  zbritja        Float
  metoda_pageses String

  klient  Klientet          @relation(fields: [klient_id], references: [id])
  punetor Punetoret         @relation(fields: [punetor_id], references: [punetor_id])
  detajet Detajet_Shitjes[]
}

model Detajet_Shitjes {
  detal_id    Int   @id @default(autoincrement())
  shitje_id   Int
  parfum_id   Int
  sasia       Int
  cmimi_njesi Float
  cmimi_total Float

  shitje Shitjet @relation(fields: [shitje_id], references: [shitje_id])
  parfum Parfum  @relation(fields: [parfum_id], references: [parfum_id])
}

model Porosite_Furnitoreve {
  porosi_id     Int       @id @default(autoincrement())
  furnitor_id   Int
  data_porosise DateTime
  shuma_totale  Float
  statusi       String
  data_pranimit DateTime?

  furnitor Furnitoret                    @relation(fields: [furnitor_id], references: [furnitor_id])
  detajet  Detajet_Porosise_Furnitorit[]
}

model Detajet_Porosise_Furnitorit {
  detal_id    Int   @id @default(autoincrement())
  porosi_id   Int
  parfum_id   Int
  sasia       Int
  cmimi_njesi Float
  cmimi_total Float

  porosi Porosite_Furnitoreve @relation(fields: [porosi_id], references: [porosi_id])
  parfum Parfum               @relation(fields: [parfum_id], references: [parfum_id])
}
